/bin/
/dist/
*.test
*.out
.DS_Store
# embedded UI build output (regenerated by vite; M13). Keep the dir's contents ignored but
# commit a .gitkeep placeholder so `//go:embed all:dist` compiles before the SPA is built
# (CI go build/lint/test and the Docker build rely on this).
/internal/ui/dist/*
!/internal/ui/dist/.gitkeep
/internal/benchui/dist/*
!/internal/benchui/dist/.gitkeep
/ui/node_modules/
/ui/gen/
# standalone static documentation site (regenerated by `make docs-site` / `npm run build:docs`)
/docs-site/
/.wavespan-data/
/cmd/wavespan-node/.wavespan-data/
ui/node_modules/
tests/harness/repro/repro_*.json

# perf tooling artifacts
perf-report/
*.pb.gz
/wavespan-node
/wavespan-profile
/wavespan-bench

# Local secrets (e.g. GITHUB_TOKEN for CI setup) — never commit
.env
.env.*

.worktrees/
